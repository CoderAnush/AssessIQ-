# ============================================
# AssessIQ AI - Environment Configuration
# ============================================
# Copy this to .env and fill in with your actual values
# NEVER commit the actual .env file to version control

# ---- REQUIRED: LLM Configuration ----
# Get your Gemini API key from: https://ai.google.dev/
GEMINI_API_KEY=your_gemini_api_key_here

# ---- Data Paths ----
# These paths should already exist after running: python scripts/build_pipeline.py
CATALOG_PATH=data/processed/catalog_processed.json
FAISS_INDEX_PATH=data/processed/faiss_index.bin
FAISS_METADATA_PATH=data/processed/faiss_metadata.json
BM25_INDEX_PATH=data/processed/bm25_index.pkl
EMBEDDINGS_PATH=data/processed/embeddings.npy
EMBEDDINGS_MODEL=all-MiniLM-L6-v2

# ---- API Configuration ----
API_PORT=8000
API_HOST=0.0.0.0
ENVIRONMENT=development

# ---- Retrieval Parameters ----
# Weights for hybrid search (must sum to 1.0)
# - 0.7 FAISS semantic search (catches conceptual matches)
# - 0.3 BM25 keyword search (catches exact matches)
SEMANTIC_SEARCH_WEIGHT=0.7
BM25_SEARCH_WEIGHT=0.3

# Top-K results to retrieve before ranking
TOP_K_RETRIEVAL=20

# Top-K final recommendations to return
MAX_RECOMMENDATIONS=10

# ---- Conversation Parameters ----
# Maximum turns allowed (user + assistant)
MAX_CONVERSATION_TURNS=8

# Request timeout in seconds (for API calls)
REQUEST_TIMEOUT_SECONDS=30

# Gemini API timeout in seconds
GEMINI_TIMEOUT_SECONDS=15

# ---- Logging Configuration ----
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=logs/assessiq.log

# ---- Monitoring ----
ENABLE_METRICS=true

# ---- Development Flags ----
DEBUG=false
ENABLE_TEST_ROUTES=false

# ---- Gemini Model Configuration ----
# Using Gemini 2.0 Flash (fast, cost-effective, reliable)
GEMINI_MODEL=gemini-2.0-flash
GEMINI_MAX_TOKENS=1024
GEMINI_TEMPERATURE=0.7
GEMINI_TOP_P=0.95
